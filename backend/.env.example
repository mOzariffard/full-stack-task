# Copy this to .env and fill in values
NODE_ENV=development
PORT=4000

# PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/drop_system"

# JWT - use a random 32+ character secret in production
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="change-me-to-a-long-random-secret-at-least-32-chars"
JWT_EXPIRES_IN="7d"

# Reservation TTL in minutes
RESERVATION_TTL_MINUTES=5

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# CORS - comma-separated origins allowed
CORS_ORIGIN="http://localhost:5173,https://your-app.pxxl.app"

# Logging level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info
